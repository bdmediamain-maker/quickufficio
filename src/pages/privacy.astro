---
import PageLayout from '~/layouts/PageLayout.astro';
import ClayHero from '~/components/sections/ClayHero.astro';

// Privacy policy generata via Iubenda — codice esistente del brief: 33601357
const IUBENDA_PRIVACY = 'https://www.iubenda.com/privacy-policy/33601357';
const IUBENDA_COOKIE = 'https://www.iubenda.com/privacy-policy/33601357/cookie-policy';
---
<PageLayout
  title="Privacy & Cookie policy"
  description="Privacy policy e cookie policy di Quickufficio.com Srls. Trattamento dati personali, finalità, base giuridica, diritti dell'interessato. Conforme GDPR."
  noindex={true}
  blobs="warm"
>
  <ClayHero
    badge="Documenti legali"
    title="Privacy & Cookie policy"
    size="sm"
    subtitle="Tutto quello che facciamo con i tuoi dati personali, raccontato in modo trasparente. Aggiornato secondo GDPR e linee guida Garante Privacy italiano."
  />

  <section class="container-clay py-12">
    <div class="grid lg:grid-cols-2 gap-8">
      <div
        class="glass-clay rounded-[32px] overflow-hidden"
        style="box-shadow: var(--shadow-clay-card);"
      >
        <header class="p-5 sm:p-6 lg:p-8 lg:p-10 border-b border-clay-foreground/10">
          <h2 class="text-3xl font-black tracking-tight" style="font-family: Nunito, sans-serif;">
            Privacy policy
          </h2>
          <p class="mt-2 text-clay-muted font-medium" style="font-family: 'DM Sans', sans-serif;">
            Generata e ospitata da Iubenda · codice 33601357
          </p>
        </header>
        <div class="aspect-[3/4]">
          <iframe
            src={IUBENDA_PRIVACY}
            title="Privacy policy completa"
            class="h-full w-full border-0"
            loading="lazy"
          ></iframe>
        </div>
        <div class="p-6 border-t border-clay-foreground/10 text-sm text-clay-muted font-medium" style="font-family: 'DM Sans', sans-serif;">
          <a href={IUBENDA_PRIVACY} target="_blank" rel="noopener" class="text-clay-accent hover:underline">
            Apri la privacy policy completa in una nuova scheda →
          </a>
        </div>
      </div>

      <div
        id="cookies"
        class="glass-clay rounded-[32px] overflow-hidden"
        style="box-shadow: var(--shadow-clay-card);"
      >
        <header class="p-5 sm:p-6 lg:p-8 lg:p-10 border-b border-clay-foreground/10">
          <h2 class="text-3xl font-black tracking-tight" style="font-family: Nunito, sans-serif;">
            Cookie policy
          </h2>
          <p class="mt-2 text-clay-muted font-medium" style="font-family: 'DM Sans', sans-serif;">
            Tipi di cookie usati, finalità, periodi conservazione.
          </p>
        </header>
        <div class="aspect-[3/4]">
          <iframe
            src={IUBENDA_COOKIE}
            title="Cookie policy completa"
            class="h-full w-full border-0"
            loading="lazy"
          ></iframe>
        </div>
        <div class="p-6 border-t border-clay-foreground/10 text-sm text-clay-muted font-medium" style="font-family: 'DM Sans', sans-serif;">
          <a href={IUBENDA_COOKIE} target="_blank" rel="noopener" class="text-clay-accent hover:underline">
            Apri la cookie policy completa in una nuova scheda →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-clay py-12">
    <div
      class="glass-clay rounded-[32px] p-5 sm:p-6 lg:p-8 lg:p-10"
      style="box-shadow: var(--shadow-clay-card);"
    >
      <h2 class="text-2xl sm:text-3xl font-black tracking-tight mb-4" style="font-family: Nunito, sans-serif;">
        Titolare del trattamento
      </h2>
      <div class="grid sm:grid-cols-2 gap-6 text-clay-foreground font-medium" style="font-family: 'DM Sans', sans-serif;">
        <address class="not-italic">
          <strong>Quickufficio.com Srls</strong><br/>
          Susa (TO)<br/>
          Italia
        </address>
        <div>
          <p><strong>Email:</strong> <a href="mailto:info@quickufficio.com" class="text-clay-accent hover:underline">info@quickufficio.com</a></p>
          <p><strong>Telefono:</strong> <a href="tel:+390122675000" class="text-clay-accent hover:underline">0122 675000</a></p>
          <p class="mt-3 text-sm text-clay-muted">
            Per esercitare i tuoi diritti GDPR (accesso, rettifica, cancellazione, portabilità, opposizione, limitazione) scrivici all'email sopra indicata.
          </p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
