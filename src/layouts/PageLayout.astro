---
import BaseLayout from './BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import StickyCTA from '~/components/layout/StickyCTA.astro';
import ClayBlobs from '~/components/layout/ClayBlobs.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  /** Schema blob colore — vedi ClayBlobs */
  blobs?: 'warm' | 'cool' | 'sunset' | 'sage' | false;
  /** Nascondi sticky CTA mobile (es. su /prenota-demo o /contatti) */
  hideStickyCta?: boolean;
}

const { blobs = 'warm', hideStickyCta = false, ...rest } = Astro.props;
---
<BaseLayout {...rest}>
  <slot name="head" slot="head" />
  {blobs !== false && <ClayBlobs scheme={blobs} count={4} />}
  <Header />
  <main id="main" class="relative pt-24 sm:pt-28 pb-24 lg:pb-12">
    <slot />
  </main>
  <Footer />
  {!hideStickyCta && <StickyCTA />}
</BaseLayout>
