---
/**
 * Logo Quickufficio.
 * Asset: public/images/brand/logo-{64|128|256}.{png|webp} (chroma-keyed da PNG fornita da BD Media)
 */
interface Props {
  class?: string;
  /** default = icona + wordmark, compact = solo icona */
  variant?: 'default' | 'compact';
  /** Altezza dell'icona in px (default 40 desktop) */
  size?: number;
}

const { class: className = '', variant = 'default', size = 40 } = Astro.props;
---
<a href="/" class={`inline-flex items-center gap-3 group ${className}`} aria-label="Quickufficio — torna alla home">
  <picture class="shrink-0 inline-block">
    <source
      type="image/webp"
      srcset={`/images/brand/logo-64.webp 1x, /images/brand/logo-128.webp 2x, /images/brand/logo-256.webp 4x`}
    />
    <img
      src="/images/brand/logo-128.png"
      srcset="/images/brand/logo-64.png 1x, /images/brand/logo-128.png 2x, /images/brand/logo-256.png 4x"
      alt="Quickufficio logo"
      width={size}
      height={size}
      class="block transition-transform duration-300 group-hover:scale-105"
      style={`height: ${size}px; width: auto;`}
      loading="eager"
      decoding="async"
    />
  </picture>
  {variant === 'default' && (
    <span
      class="text-xl font-black tracking-tight text-current leading-none"
      style="font-family: Nunito, sans-serif;"
    >Quickufficio</span>
  )}
</a>
