---
import Logo from '~/components/ui/Logo.astro';

const phone = '+390122675000';
const phoneDisplay = '0122 675000';
const email = 'info@quickufficio.com';
const year = 2026;

const cols = [
  {
    title: 'Soluzioni',
    items: [
      { label: 'Software ristoranti', href: '/ristoranti' },
      { label: 'Software hotel',      href: '/hotel' },
      { label: 'Hardware',            href: '/hardware' },
      { label: 'My Self Order',       href: '/my-self-order' },
    ],
  },
  {
    title: 'Azienda',
    items: [
      { label: 'Chi siamo',     href: '/chi-siamo' },
      { label: 'Blog',          href: '/blog' },
      { label: 'Prenota demo',  href: '/prenota-demo' },
      { label: 'Contatti',      href: '/contatti' },
    ],
  },
  {
    title: 'Risorse',
    items: [
      { label: 'Privacy policy', href: '/privacy' },
      { label: 'Cookie policy',  href: '/privacy#cookies' },
      { label: 'Automazione Hotel', href: 'https://www.automazionehotel.com', external: true },
    ],
  },
];
---
<footer class="relative pt-24 sm:pt-32 pb-10">
  <div class="container-clay">
    <div
      class="bg-clay-canvas px-6 sm:px-10 md:px-16 py-10 sm:py-14 lg:py-16 md:py-20 rounded-[40px] sm:rounded-[60px]"
      style="box-shadow: var(--shadow-clay-surface);"
    >
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12">
        <div class="md:col-span-4">
          <Logo class="text-clay-foreground" variant="default" />
          <p class="mt-5 text-clay-muted leading-relaxed font-medium max-w-sm">
            Software gestionali e hardware professionali per Hotel, Ristoranti, Bar e B&amp;B.
            20 anni di esperienza Ho.Re.Ca. Sede operativa Susa (TO).
          </p>
          <div class="mt-6 flex flex-col gap-2">
            <a href={`tel:${phone}`} class="inline-flex items-center gap-2 text-clay-foreground hover:text-clay-accent transition-colors font-bold" style="font-family: Nunito, sans-serif;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              {phoneDisplay}
            </a>
            <a href={`mailto:${email}`} class="inline-flex items-center gap-2 text-clay-foreground hover:text-clay-accent transition-colors font-medium" style="font-family: 'DM Sans', sans-serif;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
              {email}
            </a>
          </div>
        </div>

        {cols.map((col) => (
          <div class="md:col-span-2 lg:col-span-2">
            <h3 class="text-xs uppercase tracking-widest text-clay-muted mb-4 font-bold" style="font-family: 'DM Sans', sans-serif;">
              {col.title}
            </h3>
            <ul class="flex flex-col gap-3">
              {col.items.map((it) => (
                <li>
                  <a
                    href={it.href}
                    target={(it as any).external ? '_blank' : undefined}
                    rel={(it as any).external ? 'noopener' : undefined}
                    class="text-clay-foreground hover:text-clay-accent transition-colors font-medium"
                    style="font-family: 'DM Sans', sans-serif;"
                  >
                    {it.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <div class="md:col-span-2 lg:col-span-2">
          <h3 class="text-xs uppercase tracking-widest text-clay-muted mb-4 font-bold" style="font-family: 'DM Sans', sans-serif;">
            Sede
          </h3>
          <address class="not-italic text-clay-foreground leading-relaxed font-medium" style="font-family: 'DM Sans', sans-serif;">
            Quickufficio.com Srls<br />
            Susa (TO)<br />
            Italia
          </address>
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-clay-foreground/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="text-sm text-clay-muted font-medium">
          © {year} Quickufficio.com Srls — Tutti i diritti riservati
        </p>
        <p class="text-sm text-clay-muted font-medium">
          Built by <a href="https://bdtrsrl.com" class="text-clay-accent hover:underline" target="_blank" rel="noopener">BD Media</a>
        </p>
      </div>
    </div>
  </div>
</footer>
