---
import Logo from '~/components/ui/Logo.astro';
import ClayButton from '~/components/ui/ClayButton.astro';

interface NavItem { label: string; href: string; }
const nav: NavItem[] = [
  { label: 'Ristoranti',    href: '/ristoranti' },
  { label: 'Hotel',         href: '/hotel' },
  { label: 'Hardware',      href: '/hardware' },
  { label: 'My Self Order', href: '/my-self-order' },
  { label: 'Chi Siamo',     href: '/chi-siamo' },
  { label: 'Blog',          href: '/blog' },
];

const phone = '+390122675000';
const phoneDisplay = '0122 675000';
const currentPath = Astro.url.pathname;
---
<header
  id="site-header"
  class="fixed top-3 left-0 right-0 z-40 px-3 sm:px-6 transition-all duration-300"
>
  <nav
    class="container-clay glass-clay flex items-center justify-between gap-4 h-16 sm:h-20 px-4 sm:px-6 rounded-[28px] sm:rounded-[40px]"
    style="box-shadow: var(--shadow-clay-card);"
    aria-label="Navigazione principale"
  >
    <Logo class="text-clay-foreground" variant="default" />

    <ul class="hidden lg:flex items-center gap-1">
      {nav.map((item) => {
        const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <li>
            <a
              href={item.href}
              class={[
                'px-4 py-2 rounded-xl text-sm font-bold transition-all duration-200 hover:bg-clay-canvas/60',
                isActive ? 'text-clay-accent' : 'text-clay-foreground',
              ].join(' ')}
              style="font-family: 'DM Sans', sans-serif;"
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="hidden md:flex items-center gap-3">
      <a
        href={`tel:${phone}`}
        class="hidden lg:inline-flex items-center gap-2 px-3 py-2 text-sm font-bold text-clay-foreground hover:text-clay-accent transition-colors"
        style="font-family: Nunito, sans-serif;"
        aria-label={`Chiama Quickufficio al ${phoneDisplay}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {phoneDisplay}
      </a>
      <ClayButton href="/prenota-demo" variant="primary" size="sm">
        Prenota demo
      </ClayButton>
    </div>

    <button
      id="mobile-menu-toggle"
      type="button"
      class="lg:hidden inline-flex items-center justify-center h-10 w-10 rounded-xl glass-clay text-clay-foreground"
      style="box-shadow: var(--shadow-clay-card);"
      aria-label="Apri menu di navigazione"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </nav>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-50 hidden flex-col bg-clay-canvas/95 backdrop-blur-xl px-4 pt-4 pb-8 overflow-y-auto"
  aria-hidden="true"
>
  <div class="flex items-center justify-between mb-6">
    <Logo class="text-clay-foreground" variant="default" />
    <button
      id="mobile-menu-close"
      type="button"
      class="inline-flex items-center justify-center h-10 w-10 rounded-xl glass-clay text-clay-foreground"
      style="box-shadow: var(--shadow-clay-card);"
      aria-label="Chiudi menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <ul class="flex flex-col gap-2">
    {nav.map((item) => (
      <li>
        <a
          href={item.href}
          class="block px-5 py-4 rounded-2xl glass-clay text-xl font-extrabold text-clay-foreground"
          style="box-shadow: var(--shadow-clay-card); font-family: Nunito, sans-serif;"
        >
          {item.label}
        </a>
      </li>
    ))}
    <li class="mt-2">
      <a
        href="/contatti"
        class="block px-5 py-4 rounded-2xl glass-clay text-xl font-extrabold text-clay-foreground"
        style="box-shadow: var(--shadow-clay-card); font-family: Nunito, sans-serif;"
      >
        Contatti
      </a>
    </li>
  </ul>
  <div class="mt-8 flex flex-col gap-3">
    <ClayButton href="/prenota-demo" variant="primary" block size="lg">Prenota demo</ClayButton>
    <ClayButton href={`tel:${phone}`} variant="ghost" block size="lg">{phoneDisplay}</ClayButton>
  </div>
</div>

<script>
  // Init wrapped in function così si può ri-eseguire dopo View Transitions Astro
  function initHeader() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const close = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    const header = document.getElementById('site-header');

    if (!toggle || !menu) return;

    // Evita doppia bind dei listener se initHeader viene rieseguito
    if (toggle.dataset.menuBound === '1') return;
    toggle.dataset.menuBound = '1';

    function openMenu() {
      menu!.classList.remove('hidden');
      menu!.classList.add('flex');
      menu!.setAttribute('aria-hidden', 'false');
      toggle!.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      menu!.classList.add('hidden');
      menu!.classList.remove('flex');
      menu!.setAttribute('aria-hidden', 'true');
      toggle!.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', openMenu);
    close?.addEventListener('click', closeMenu);
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

    // Escape per chiudere
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) closeMenu();
    });

    // Sticky header scale-down on scroll
    function onScroll() {
      if (!header) return;
      const y = window.scrollY;
      if (y > 24) {
        header.classList.add('top-2');
        header.classList.remove('top-3');
      } else {
        header.classList.add('top-3');
        header.classList.remove('top-2');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  initHeader();
  // Re-init dopo navigazione View Transitions Astro — il vecchio DOM viene swappato,
  // i listener vanno re-attaccati al nuovo button/menu
  document.addEventListener('astro:page-load', initHeader);
</script>
