---
/**
 * Sticky CTA mobile — bottom bar con "Prenota demo" + "Chiama".
 * Brief §7 UX & Conversione — "Sticky CTA mobile (banner bottom con Prenota demo + WhatsApp)".
 * Visibile solo < lg breakpoint.
 */
const phone = '+390122675000';
---
<div class="lg:hidden fixed bottom-0 left-0 right-0 z-30 p-3 pointer-events-none">
  <div
    class="container-clay flex items-center gap-3 px-3 py-3 rounded-[24px] glass-clay pointer-events-auto"
    style="box-shadow: var(--shadow-clay-card);"
  >
    <a
      href={`tel:${phone}`}
      class="flex items-center justify-center h-12 w-12 rounded-2xl glass-clay text-clay-foreground shrink-0"
      style="box-shadow: var(--shadow-clay-card);"
      aria-label="Chiama 0122 675000"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
    </a>
    <a
      href="/prenota-demo"
      class="flex-1 inline-flex items-center justify-center h-12 px-5 rounded-2xl clay-button-primary text-white font-bold whitespace-nowrap"
      style="font-family: Nunito, sans-serif; box-shadow: var(--shadow-clay-button);"
    >
      Prenota demo →
    </a>
  </div>
</div>
