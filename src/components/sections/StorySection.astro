---
/**
 * Sezione storia/about — split 50/50 con foto editorial + testo lungo.
 * Riusabile per "Stiamo aiutando più di 100 attività" homepage e per Chi Siamo.
 */
import ClayBadge from '~/components/ui/ClayBadge.astro';

interface Props {
  badge?: string;
  title: string;
  highlight?: string;
  paragraphs: string[];
  image?: string;
  imageAlt?: string;
  imageSide?: 'left' | 'right';
  signature?: string;
}
const {
  badge,
  title,
  highlight,
  paragraphs,
  image,
  imageAlt = '',
  imageSide = 'right',
  signature,
} = Astro.props;

const titleParts = highlight ? title.split(highlight) : [title];
---
<section class="container-clay py-10 sm:py-16 lg:py-24">
  <div class={`grid lg:grid-cols-12 gap-8 sm:gap-12 lg:gap-16 items-center ${imageSide === 'left' ? 'lg:[&>*:first-child]:order-2' : ''}`}>
    <div data-reveal={imageSide === 'right' ? 'left' : 'right'} class="lg:col-span-7">
      {badge && <ClayBadge variant="bordeaux" size="md" class="mb-5">{badge}</ClayBadge>}
      <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight" style="font-family: Nunito, sans-serif;">
        {highlight ? (
          <>
            {titleParts[0]}<span class="clay-text-gradient">{highlight}</span>{titleParts[1]}
          </>
        ) : title}
      </h2>
      <div class="mt-4 sm:mt-6 flex flex-col gap-3 sm:gap-4 text-base sm:text-lg leading-relaxed text-clay-muted font-medium" style="font-family: 'DM Sans', sans-serif;">
        {paragraphs.map((p) => (<p>{p}</p>))}
      </div>
      {signature && (
        <p class="mt-6 text-xl text-clay-foreground" style="font-family: Nunito, sans-serif; font-weight: 800;">
          — {signature}
        </p>
      )}
    </div>
    {image && (
      <div data-reveal={imageSide === 'right' ? 'right' : 'left'} data-reveal-delay="100" class="lg:col-span-5">
        <div
          class="relative overflow-hidden rounded-[28px] sm:rounded-[32px] aspect-[4/3] sm:aspect-[4/5] bg-clay-input-bg"
          style="box-shadow: var(--shadow-clay-card);"
        >
          <img src={image} alt={imageAlt} class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
    )}
  </div>
</section>
