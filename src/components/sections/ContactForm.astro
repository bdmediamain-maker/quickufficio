---
import ClayInput from '~/components/ui/ClayInput.astro';
import ClayTextarea from '~/components/ui/ClayTextarea.astro';
import ClayCheckbox from '~/components/ui/ClayCheckbox.astro';
import ClayButton from '~/components/ui/ClayButton.astro';

interface Props {
  title?: string;
  subtitle?: string;
  action?: string;
  origin?: string;
}

const {
  title = 'Scrivici',
  subtitle = 'Rispondiamo entro 24h lavorative. Per emergenze chiama 0122 675000.',
  action = '/api/contact',
  origin = 'generic',
} = Astro.props;
---
<section class="container-clay py-10 sm:py-16 lg:py-24">
  <div
    data-reveal="scale"
    class="rounded-[40px] sm:rounded-[60px] bg-clay-canvas p-5 sm:p-8 md:p-10 lg:p-16 grid lg:grid-cols-12 gap-10"
    style="box-shadow: var(--shadow-clay-surface);"
  >
    <div data-reveal="left" data-reveal-delay="100" class="lg:col-span-5">
      <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight" style="font-family: Nunito, sans-serif;">
        {title}
      </h2>
      <p class="mt-5 text-lg text-clay-muted leading-relaxed font-medium" style="font-family: 'DM Sans', sans-serif;">
        {subtitle}
      </p>
      <div class="mt-8 flex flex-col gap-4 text-clay-foreground font-medium" style="font-family: 'DM Sans', sans-serif;">
        <a href="tel:+390122675000" class="inline-flex items-center gap-3 hover:text-clay-accent transition-colors">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl clay-orb-copper text-white" style="box-shadow: var(--shadow-clay-card);" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </span>
          <span class="font-bold text-lg" style="font-family: Nunito, sans-serif;">0122 675000</span>
        </a>
        <a href="mailto:info@quickufficio.com" class="inline-flex items-center gap-3 hover:text-clay-accent transition-colors">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl clay-orb-bordeaux text-white" style="box-shadow: var(--shadow-clay-card);" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <span class="font-bold text-lg" style="font-family: Nunito, sans-serif;">info@quickufficio.com</span>
        </a>
        <p class="mt-2 text-sm text-clay-muted" style="font-family: 'DM Sans', sans-serif;">
          <strong class="text-clay-foreground">Orari:</strong> Lun-Ven 9:00–18:00<br/>
          Assistenza emergenze attiva anche sera e weekend
        </p>
      </div>
    </div>

    <form method="POST" action={action} class="lg:col-span-7 flex flex-col gap-5">
      <input type="hidden" name="origin" value={origin} />
      <div class="grid sm:grid-cols-2 gap-5">
        <ClayInput name="nome" label="Nome e cognome" required autocomplete="name" />
        <ClayInput type="tel" name="telefono" label="Telefono" required autocomplete="tel" />
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        <ClayInput type="email" name="email" label="Email" required autocomplete="email" />
        <div class="flex flex-col gap-2">
          <label for="settore" class="font-medium text-sm text-clay-foreground" style="font-family: 'DM Sans', sans-serif;">
            Tipo attività
          </label>
          <select
            id="settore"
            name="settore"
            class="w-full h-14 px-5 rounded-2xl bg-clay-input-bg text-clay-foreground font-medium focus:bg-white focus:outline-none focus:ring-4 focus:ring-clay-accent/20 transition-all duration-200"
            style="box-shadow: var(--shadow-clay-pressed); font-family: 'DM Sans', sans-serif;"
          >
            <option value="">Seleziona…</option>
            <option value="ristorante">Ristorante</option>
            <option value="hotel">Hotel</option>
            <option value="bar">Bar</option>
            <option value="pizzeria">Pizzeria</option>
            <option value="bnb">B&B</option>
            <option value="villaggio">Villaggio / Camping</option>
            <option value="altro">Altro</option>
          </select>
        </div>
      </div>
      <ClayTextarea
        name="messaggio"
        label="Il tuo messaggio"
        placeholder="Raccontaci cosa vorresti automatizzare o quale problema vuoi risolvere."
        required
        rows={5}
      />
      <ClayCheckbox name="gdpr" required>
        Ho letto la <a href="/privacy" class="text-clay-accent underline hover:no-underline">privacy policy</a> e acconsento al trattamento dei dati.
      </ClayCheckbox>
      <input type="text" name="company_website" autocomplete="off" tabindex="-1" class="absolute opacity-0 pointer-events-none h-0 w-0" aria-hidden="true" />
      <div class="pt-2">
        <ClayButton as="button" type="submit" variant="primary" size="lg" block>
          Invia messaggio →
        </ClayButton>
      </div>
    </form>
  </div>
</section>
