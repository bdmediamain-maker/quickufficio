---
import BookingForm from './BookingForm.astro';
import ClayCard from '~/components/ui/ClayCard.astro';

interface Props {
  variant?: 'compact' | 'full';
  origin?: string;
  title?: string;
  subtitle?: string;
}
const {
  variant = 'full',
  origin = 'embed',
  title = 'Prenota una demo con Sergio',
  subtitle = '30-60 minuti, gratis, niente venditori. Sergio ti mostra i software in azione e ti aiuta a capire cosa funziona per la tua attività.',
} = Astro.props;

const expectations = [
  { icon: '⏱️', label: '30-60 minuti, no impegno' },
  { icon: '🎥', label: 'Video call (link via email)' },
  { icon: '🖥️', label: 'Sergio condivide schermo, vedi i software in azione' },
  { icon: '💬', label: 'Domande libere, niente pitch commerciale' },
  { icon: '📅', label: 'Disponibilità: lun-ven 9-18' },
];
---
<section class="container-clay py-10 sm:py-16 lg:py-24">
  {variant === 'full' ? (
    <div
      data-reveal="scale"
      class="rounded-[40px] sm:rounded-[60px] bg-clay-canvas p-5 sm:p-8 md:p-10 lg:p-16"
      style="box-shadow: var(--shadow-clay-surface);"
    >
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
        <div class="lg:col-span-5">
          <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight" style="font-family: Nunito, sans-serif;">
            {title}
          </h2>
          <p class="mt-5 text-lg text-clay-muted leading-relaxed font-medium" style="font-family: 'DM Sans', sans-serif;">
            {subtitle}
          </p>
          <ul class="mt-8 flex flex-col gap-4">
            {expectations.map((e) => (
              <li class="flex items-start gap-4">
                <span class="text-2xl shrink-0" aria-hidden="true">{e.icon}</span>
                <span class="text-clay-foreground leading-relaxed font-medium" style="font-family: 'DM Sans', sans-serif;">{e.label}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="lg:col-span-7">
          <ClayCard variant="solid" radius={32} padding="lg" hover={false}>
            <BookingForm origin={origin} />
          </ClayCard>
        </div>
      </div>
    </div>
  ) : (
    <ClayCard variant="glass" radius={32} padding="lg" hover={false} class="text-center">
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight" style="font-family: Nunito, sans-serif;">
        {title}
      </h2>
      <p class="mt-3 text-clay-muted leading-relaxed font-medium max-w-xl mx-auto" style="font-family: 'DM Sans', sans-serif;">
        {subtitle}
      </p>
      <div class="mt-6">
        <a
          href="/prenota-demo"
          class="inline-flex items-center justify-center h-14 px-8 rounded-[20px] clay-button-primary text-white font-bold tracking-tight transition-all duration-200 hover:-translate-y-1"
          style="font-family: Nunito, sans-serif; box-shadow: var(--shadow-clay-button);"
        >
          Prenota demo →
        </a>
      </div>
    </ClayCard>
  )}
</section>
